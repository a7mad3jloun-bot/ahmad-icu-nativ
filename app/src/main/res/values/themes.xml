<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.AhmadQudah" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary_teal</item>
        <item name="colorPrimaryVariant">@color/primary_teal_dark</item>
        <item name="colorOnPrimary">@color/text_primary</item>
        <item name="colorSecondary">@color/secondary_indigo</item>
        <item name="colorSecondaryVariant">@color/secondary_indigo_dark</item>
        <item name="colorOnSecondary">@color/text_primary</item>
        <item name="android:colorBackground">@color/bg_dark_start</item>
        <item name="colorSurface">@color/bg_card</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOnBackground">@color/text_primary</item>
        <item name="android:statusBarColor">@color/bg_dark_start</item>
        <item name="android:navigationBarColor">@color/bg_dark_end</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:windowBackground">@drawable/bg_activation_gradient</item>
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>
    
    <style name="Theme.AhmadQudah.Activation" parent="Theme.AhmadQudah">
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowContentTransitions">true</item>
    </style>
</resources>