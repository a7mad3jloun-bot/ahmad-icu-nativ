<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- الطبقة 1: سطح زجاجي قوي -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/glass_surface"/>
            <corners android:radius="28dp"/>
        </shape>
    </item>
    
    <!-- الطبقة 2: لمعة علوية -->
    <item android:left="1dp" android:right="1dp" android:top="1dp" android:bottom="0dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/glass_highlight"/>
            <corners 
                android:topLeftRadius="28dp"
                android:topRightRadius="28dp"
                android:bottomLeftRadius="0dp"
                android:bottomRightRadius="0dp"/>
        </shape>
    </item>
    
    <!-- الطبقة 3: إطار أبيض شفاف -->
    <item>
        <shape android:shape="rectangle">
            <stroke 
                android:width="1.5dp" 
                android:color="@color/glass_border"/>
            <corners android:radius="28dp"/>
        </shape>
    </item>
    
    <!-- الطبقة 4: توهج خارجي باللون التيل -->
    <item android:left="2dp" android:right="2dp" android:top="2dp" android:bottom="2dp">
        <shape android:shape="rectangle">
            <stroke 
                android:width="0.5dp" 
                android:color="@color/glass_glow_teal"/>
            <corners android:radius="26dp"/>
        </shape>
    </item>
</layer-list>