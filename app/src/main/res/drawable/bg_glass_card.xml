<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- الطبقة 1: الزجاج الشفاف الأساسي -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/glass_white"/>
            <corners android:radius="24dp"/>
        </shape>
    </item>
    
    <!-- الطبقة 2: لمعة خفيفة في الأعلى -->
    <item android:left="1dp" android:right="1dp" android:top="1dp" android:bottom="0dp">
        <shape android:shape="rectangle">
            <solid android:color="#08FFFFFF"/>
            <corners 
                android:topLeftRadius="24dp"
                android:topRightRadius="24dp"
                android:bottomLeftRadius="0dp"
                android:bottomRightRadius="0dp"/>
        </shape>
    </item>
    
    <!-- الطبقة 3: إطار أبيض شفاف -->
    <item>
        <shape android:shape="rectangle">
            <stroke 
                android:width="1.5dp" 
                android:color="@color/glass_border"/>
            <corners android:radius="24dp"/>
        </shape>
    </item>
    
    <!-- الطبقة 4: توهج تيل خفيف حول الحواف -->
    <item android:left="2dp" android:right="2dp" android:top="2dp" android:bottom="2dp">
        <shape android:shape="rectangle">
            <stroke 
                android:width="0.5dp" 
                android:color="@color/glass_glow_teal"/>
            <corners android:radius="22dp"/>
        </shape>
    </item>
</layer-list>